---
/**
 * Landing page — /
 * Hero, API primitives overview, featured demos, getting-started CTA.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import DemoCard from '../components/DemoCard.astro';
import { getCollection } from 'astro:content';

const demos = await getCollection('demos');
const WICG_REPO = 'https://github.com/WICG/html-in-canvas';
---

<BaseLayout>
  {/* ---------- Hero ---------- */}
  <section class="hero" aria-label="Introduction">
    <p class="hero-eyebrow">WICG Specification</p>
    <h1 class="hero-heading">
      Render HTML into Canvas<span class="hero-accent"> — natively</span>
    </h1>
    <p class="hero-sub">
      The HTML-in-Canvas spec adds three primitives that let you draw
      fully-styled, accessible HTML content straight into
      <code>&lt;canvas&gt;</code> — no hacks, no libraries, no screenshots.
    </p>
    <div class="hero-actions">
      <a href="/demos/" class="btn btn-primary">Explore Demos</a>
      <a href={WICG_REPO} class="btn btn-secondary" target="_blank" rel="noopener noreferrer">
        Read the Spec
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7" /><path d="M7 7h10v10" /></svg>
      </a>
    </div>
  </section>

  {/* ---------- API Primitives ---------- */}
  <section class="primitives" aria-labelledby="primitives-heading">
    <h2 id="primitives-heading" class="section-heading">Three Primitives, One New Superpower</h2>
    <p class="section-sub">
      The spec introduces a minimal, composable API surface — each piece
      solves a distinct problem.
    </p>

    <div class="primitives-grid">
      <div class="primitive-card">
        <span class="primitive-number">1</span>
        <h3><code>layoutsubtree</code></h3>
        <p>
          Add this attribute to a <code>&lt;canvas&gt;</code> to opt its
          children into layout and hit testing — they behave like normal DOM
          elements but remain invisible until drawn.
        </p>
        <pre><code>&lt;canvas layoutsubtree&gt;
  &lt;div id="content"&gt;
    Laid out, accessible,
    ready to draw.
  &lt;/div&gt;
&lt;/canvas&gt;</code></pre>
      </div>

      <div class="primitive-card">
        <span class="primitive-number">2</span>
        <h3><code>drawElementImage()</code></h3>
        <p>
          Draws a child element into the canvas with the current transform
          applied. Works across 2D, WebGL, and WebGPU contexts.
        </p>
        <pre><code set:html={`const t = ctx.drawElementImage(
  element, x, y
);
// Sync DOM position
element.style.transform =
  t.toString();`} /></pre>
      </div>

      <div class="primitive-card">
        <span class="primitive-number">3</span>
        <h3><code>paint</code> event</h3>
        <p>
          Fires whenever a child element's rendering changes — clear the
          canvas and redraw in one efficient callback, once per frame.
        </p>
        <pre><code set:html={`canvas.onpaint = (e) =&gt; {
  ctx.reset();
  for (const el of e.changedElements) {
    ctx.drawElementImage(el, 0, 0);
  }
};`} /></pre>
      </div>
    </div>
  </section>

  {/* ---------- Why it matters ---------- */}
  <section class="why" aria-labelledby="why-heading">
    <h2 id="why-heading" class="section-heading">Why This Matters</h2>
    <div class="why-grid">
      <div class="why-item">
        <div class="why-icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
        </div>
        <h3>Accessibility built in</h3>
        <p>
          Drawn elements <em>are</em> the fallback content — the
          accessibility tree always matches what's on screen.
        </p>
      </div>
      <div class="why-item">
        <div class="why-icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        </div>
        <h3>Real CSS rendering</h3>
        <p>
          Fonts, ligatures, RTL, subpixel rendering — the browser does
          the hard work, not a polyfill.
        </p>
      </div>
      <div class="why-item">
        <div class="why-icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        </div>
        <h3>No hacks required</h3>
        <p>
          Replace <code>html2canvas</code>-style workarounds with a native API
          that's fast, correct, and privacy-preserving.
        </p>
      </div>
      <div class="why-item">
        <div class="why-icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
        </div>
        <h3>2D, WebGL &amp; WebGPU</h3>
        <p>
          One API surface that works across all three canvas contexts —
          render HTML as 3D textures, apply shaders, and more.
        </p>
      </div>
    </div>
  </section>

  {/* ---------- Featured Demos ---------- */}
  <section class="demos" aria-labelledby="demos-heading">
    <div class="section-header-row">
      <h2 id="demos-heading" class="section-heading">Featured Demos</h2>
      <a href="/demos/" class="section-link">
        View all demos
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14" /><path d="M12 5l7 7-7 7" /></svg>
      </a>
    </div>

    {demos.length > 0 ? (
      <div class="demo-grid">
        {demos.slice(0, 6).map((demo) => (
          <DemoCard
            slug={demo.id}
            title={demo.data.title}
            description={demo.data.description}
            context={demo.data.context}
            difficulty={demo.data.difficulty}
            tags={demo.data.tags}
          />
        ))}
      </div>
    ) : (
      <div class="demos-empty">
        <p>
          Demos are coming soon. Want to be the first contributor?
          <a href="/contributing/">Add a demo</a>.
        </p>
      </div>
    )}
  </section>

  {/* ---------- Getting Started ---------- */}
  <section class="getting-started" aria-labelledby="gs-heading">
    <div class="gs-card">
      <h2 id="gs-heading">Get Started</h2>
      <p>
        The HTML-in-Canvas API is available today in
        <strong>Chrome Canary</strong> and
        <strong>Brave Stable</strong> (Chromium 147+) behind the
        <code>canvas-draw-element</code> flag. Enable it, open a demo,
        and start experimenting.
      </p>
      <div class="gs-actions">
        <a href="/docs/browser-support/" class="btn btn-primary">Browser Setup Guide</a>
        {demos.length > 0 && (
          <a href={`/demos/${demos[0].id}/`} class="btn btn-secondary">Try Your First Demo</a>
        )}
      </div>
      <p class="gs-spec-link">
        Track the spec at
        <a href={WICG_REPO} target="_blank" rel="noopener noreferrer">{WICG_REPO.replace('https://', '')}</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== Hero ===== */
  .hero {
    text-align: center;
    padding: 4rem 0 3.5rem;
    max-width: 48rem;
    margin: 0 auto;
  }

  .hero-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-teal);
    margin: 0 0 1rem;
  }

  .hero-heading {
    font-size: clamp(2rem, 5vw, 3.25rem);
    line-height: 1.15;
    margin-bottom: 1.25rem;
  }

  .hero-accent {
    color: var(--color-teal);
  }

  .hero-sub {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--text-secondary);
    max-width: 38rem;
    margin: 0 auto 2rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.875rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ===== Buttons ===== */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.625rem 1.25rem;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    transition: background-color 0.15s ease, color 0.15s ease, border-color 0.15s ease, transform 0.1s ease;
  }

  .btn:hover {
    text-decoration: none;
    transform: translateY(-1px);
  }

  .btn-primary {
    background: var(--accent);
    color: var(--color-white);
  }

  .btn-primary:hover {
    background: var(--accent-hover);
    color: var(--color-white);
  }

  .btn-secondary {
    background: transparent;
    color: var(--text-primary);
    border: 1px solid var(--border-color);
  }

  .btn-secondary:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* ===== Section headings ===== */
  .section-heading {
    font-size: 1.75rem;
    margin-bottom: 0.5rem;
  }

  .section-sub {
    color: var(--text-secondary);
    max-width: 36rem;
    margin: 0 0 2rem;
  }

  .section-header-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .section-header-row .section-heading {
    margin-bottom: 0;
  }

  .section-link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.9rem;
    font-weight: 500;
    white-space: nowrap;
  }

  /* ===== Primitives ===== */
  .primitives {
    padding: 3rem 0;
    border-top: 1px solid var(--border-subtle);
  }

  .primitives-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .primitive-card {
    position: relative;
    padding: 1.5rem;
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: 10px;
    transition: border-color 0.15s ease;
  }

  .primitive-card:hover {
    border-color: var(--accent);
  }

  .primitive-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    font-size: 0.75rem;
    font-weight: 700;
    background: var(--accent);
    color: var(--color-white);
    border-radius: 50%;
    margin-bottom: 0.75rem;
  }

  .primitive-card h3 {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }

  .primitive-card p {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0 0 1rem;
  }

  .primitive-card pre {
    font-size: 0.78rem;
    line-height: 1.5;
    margin: 0;
  }

  /* ===== Why ===== */
  .why {
    padding: 3rem 0;
    border-top: 1px solid var(--border-subtle);
  }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .why-item {
    display: flex;
    gap: 1rem;
    padding: 1.25rem;
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: 10px;
  }

  .why-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    background: rgba(108, 65, 240, 0.12);
    color: var(--accent);
    border-radius: 8px;
  }

  .why-item h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .why-item p {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.55;
  }

  /* ===== Demos ===== */
  .demos {
    padding: 3rem 0;
    border-top: 1px solid var(--border-subtle);
  }

  .demo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(18rem, 1fr));
    gap: 1.25rem;
  }

  .demos-empty {
    text-align: center;
    padding: 3rem 1.5rem;
    background: var(--bg-surface);
    border: 1px dashed var(--border-color);
    border-radius: 10px;
  }

  .demos-empty p {
    color: var(--text-secondary);
    margin: 0;
  }

  /* ===== Getting Started ===== */
  .getting-started {
    padding: 3rem 0 1rem;
    border-top: 1px solid var(--border-subtle);
  }

  .gs-card {
    text-align: center;
    padding: 3rem 2rem;
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: 12px;
  }

  .gs-card h2 {
    font-size: 1.75rem;
    margin-bottom: 0.75rem;
  }

  .gs-card > p {
    max-width: 34rem;
    margin: 0 auto 1.5rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  .gs-actions {
    display: flex;
    gap: 0.875rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .gs-spec-link {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin: 0;
  }

  /* ===== Responsive ===== */
  @media (max-width: 768px) {
    .hero {
      padding: 2.5rem 0 2rem;
    }

    .primitives-grid {
      grid-template-columns: 1fr;
    }

    .why-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .hero-heading {
      font-size: 1.75rem;
    }

    .hero-sub {
      font-size: 1rem;
    }

    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .btn {
      justify-content: center;
    }

    .demo-grid {
      grid-template-columns: 1fr;
    }

    .gs-card {
      padding: 2rem 1.25rem;
    }

    .gs-actions {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
