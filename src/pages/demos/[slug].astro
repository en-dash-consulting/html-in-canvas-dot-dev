---
/**
 * Individual demo page — /demos/{slug}/
 *
 * Mounts the live demo in a shadow root on this page (rather than an iframe)
 * so that text selection, pointer events, fullscreen, and layout flow
 * naturally between the page chrome and the demo. The same demo.html file
 * is also served as a standalone document at /demos/{slug}/demo.html for
 * "Open in new tab" / fork-on-GitHub use.
 */
import { getCollection } from 'astro:content';
import { readdir, readFile } from 'node:fs/promises';
import { join } from 'node:path';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SourceViewer from '../../components/SourceViewer.astro';
import { parseDemoHtml } from '../../lib/parseDemoHtml';

/**
 * GitHub repository base URL.
 * Update when the repo is created and pushed.
 */
const GITHUB_REPO = 'https://github.com/nicholasgasior/html-in-canvas-dot-dev';

export async function getStaticPaths() {
  const demos = await getCollection('demos');
  return demos.map((demo) => ({
    params: { slug: demo.id },
    props: { demo },
  }));
}

const { demo } = Astro.props;
const {
  title,
  description,
  context,
  difficulty,
  tags,
  author,
  dateCreated,
  dateUpdated,
  features,
  browserSupport,
} = demo.data;

// ---------------------------------------------------------------------------
// Read source files from the demo directory for the SourceViewer
// ---------------------------------------------------------------------------
const demoDir = join(process.cwd(), 'src/content/demos', demo.id);
const entries = await readdir(demoDir, { withFileTypes: true });

/** File extensions we display as source code in the viewer */
const textExtensions = new Set([
  'html', 'css', 'js', 'ts', 'json', 'svg', 'glsl', 'wgsl',
]);

const sourceFiles: { filename: string; code: string; lang: string }[] = [];

for (const entry of entries) {
  if (!entry.isFile() || entry.name === 'meta.json') continue;
  const ext = entry.name.split('.').pop()?.toLowerCase() ?? '';
  if (!textExtensions.has(ext)) continue;
  const content = await readFile(join(demoDir, entry.name), 'utf-8');
  sourceFiles.push({ filename: entry.name, code: content, lang: ext });
}

// demo.html first, then alphabetical
sourceFiles.sort((a, b) => {
  if (a.filename === 'demo.html') return -1;
  if (b.filename === 'demo.html') return 1;
  return a.filename.localeCompare(b.filename);
});

// ---------------------------------------------------------------------------
// Parse the demo HTML for shadow-DOM mounting
// ---------------------------------------------------------------------------
const demoHtmlRaw = await readFile(join(demoDir, 'demo.html'), 'utf-8');
const parsedDemo = parseDemoHtml(demoHtmlRaw);

// ---------------------------------------------------------------------------
// Display helpers
// ---------------------------------------------------------------------------
const contextLabels: Record<string, string> = {
  '2d': '2D',
  webgl: 'WebGL',
  webgpu: 'WebGPU',
};

const difficultyLabels: Record<string, string> = {
  beginner: 'Beginner',
  intermediate: 'Intermediate',
  advanced: 'Advanced',
};

const demoUrl = `/demos/${demo.id}/demo.html`;
const githubUrl = `${GITHUB_REPO}/tree/main/src/content/demos/${demo.id}`;
---

<BaseLayout title={title} description={description}>
  <div class="demo-page">
    {/* ------- Slim title bar ------- */}
    <div class="demo-bar">
      <a href="/demos/" class="back-link" aria-label="Back to demos">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
        Demos
      </a>
      <span class="bar-divider" aria-hidden="true"></span>
      <h1 class="bar-title">{title}</h1>
      <span class={`context-badge context-${context}`}>
        {contextLabels[context]}
      </span>
      <span class={`difficulty-badge difficulty-${difficulty}`}>
        {difficultyLabels[difficulty]}
      </span>
      <div class="bar-actions">
        <a
          href={demoUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="bar-action"
          title="Open in new tab"
          aria-label="Open in new tab"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        </a>
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="bar-action"
          title="View source on GitHub"
          aria-label="View source on GitHub"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        </a>
      </div>
    </div>

    {/* ------- Live demo (shadow DOM mount, full-bleed) ------- */}
    <div class="demo-stage-wrapper">
      <div class="demo-stage" id="demo-stage" data-demo-slug={demo.id}>
        <button
          type="button"
          id="demo-fullscreen-btn"
          class="demo-fullscreen-btn"
          aria-label="Toggle fullscreen"
          title="Toggle fullscreen"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M3 9V5a2 2 0 0 1 2-2h4" />
            <path d="M21 9V5a2 2 0 0 0-2-2h-4" />
            <path d="M3 15v4a2 2 0 0 0 2 2h4" />
            <path d="M21 15v4a2 2 0 0 1-2 2h-4" />
          </svg>
        </button>
        <div class="demo-fallback" id="demo-fallback" hidden>
          <div class="fallback-content">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="32"
              height="32"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z" />
              <line x1="12" y1="9" x2="12" y2="13" />
              <line x1="12" y1="17" x2="12.01" y2="17" />
            </svg>
            <p class="fallback-title">API Unavailable</p>
            <p class="fallback-text">
              This demo requires <strong>Chrome Canary</strong> with the
              <code>canvas-draw-element</code> flag enabled.
            </p>
            <a href="/docs/browser-support/" class="fallback-link">
              Setup instructions &rarr;
            </a>
          </div>
        </div>
      </div>
      {/*
        The demo's parsed CSS + body markup live in this template (no
        scripts — those are shipped as inert JSON below). The client
        script attaches a shadow root to #demo-stage, clones the
        template content in, then materializes each script body as a
        fresh <script> element so it runs in the shadow context.
      */}
      <template id="demo-template">
        <Fragment set:html={parsedDemo.headLinks} />
        <style set:html={parsedDemo.styles} />
        <Fragment set:html={parsedDemo.bodyContent} />
      </template>
      <script
        is:inline
        id="demo-scripts"
        type="application/json"
        set:html={JSON.stringify(parsedDemo.scripts)}
      />
    </div>

    {/* ------- Description ------- */}
    <p class="demo-description">{description}</p>

    {/* ------- Details strip ------- */}
    <aside class="demo-details">
      {author && (
        <div class="detail-field">
          <span class="field-label">Author</span>
          <span class="field-value">{author}</span>
        </div>
      )}

      {dateCreated && (
        <div class="detail-field">
          <span class="field-label">Created</span>
          <span class="field-value">{dateCreated}</span>
        </div>
      )}

      {dateUpdated && (
        <div class="detail-field">
          <span class="field-label">Updated</span>
          <span class="field-value">{dateUpdated}</span>
        </div>
      )}

      {features.length > 0 && (
        <div class="detail-field detail-field-wide">
          <span class="field-label">API Features</span>
          <div class="feature-list">
            {features.map((f: string) => (
              <code class="feature-tag">{f}</code>
            ))}
          </div>
        </div>
      )}

      <div class="detail-field">
        <span class="field-label">Browser Support</span>
        <div class="browser-list">
          <span class={`browser-badge ${browserSupport.chrome ? 'supported' : 'unsupported'}`}>
            Chrome
          </span>
          <span class={`browser-badge ${browserSupport.firefox ? 'supported' : 'unsupported'}`}>
            Firefox
          </span>
          <span class={`browser-badge ${browserSupport.safari ? 'supported' : 'unsupported'}`}>
            Safari
          </span>
        </div>
      </div>

      {tags.length > 0 && (
        <div class="detail-field detail-field-wide">
          <span class="field-label">Tags</span>
          <div class="tag-list">
            {tags.map((tag: string) => (
              <span class="demo-tag">{tag}</span>
            ))}
          </div>
        </div>
      )}
    </aside>

    {/* ------- Source code ------- */}
    <section class="demo-source">
      <h2>Source Code</h2>
      <SourceViewer files={sourceFiles} />
    </section>
  </div>
</BaseLayout>

<script>
  /**
   * Mount the demo's parsed HTML/CSS/JS inside a shadow root attached to
   * #demo-stage. We use a <template> to carry the inert markup, clone it
   * into the shadow root, then re-create <script> elements so the demo's
   * JavaScript actually executes (cloned scripts do not).
   *
   * Two subtleties:
   *   1. `document.currentScript` is unreliable for dynamically-inserted
   *      scripts, so we hand the demo its shadow root via a transient
   *      `window.__demoRoot` global it reads at the top of its body.
   *   2. We wrap each demo script's body in an IIFE so its top-level
   *      declarations don't leak to window — that lets re-mounts (e.g.
   *      after astro:after-swap) work without "already declared" errors.
   */
  type DemoScriptDef = { src?: string; type?: string; body: string };

  async function mountDemo() {
    const stage = document.getElementById('demo-stage');
    const template = document.getElementById(
      'demo-template',
    ) as HTMLTemplateElement | null;
    const scriptsHolder = document.getElementById('demo-scripts');
    if (!stage || !template || !scriptsHolder) return;
    if (stage.shadowRoot) return; // already mounted

    let scripts: DemoScriptDef[];
    try {
      scripts = JSON.parse(scriptsHolder.textContent || '[]');
    } catch {
      scripts = [];
    }

    const shadow = stage.attachShadow({ mode: 'open' });
    shadow.appendChild(template.content.cloneNode(true));

    // Materialize each demo script as a fresh <script> element so it
    // executes inside the shadow root, in document order. External
    // scripts (Three.js etc.) are awaited so subsequent inline scripts
    // can use their globals. Inline scripts are wrapped in an IIFE so
    // their top-level declarations stay scoped — re-mounts (e.g.
    // astro:after-swap) won't trip "already declared" errors. Each
    // inline script is handed its shadow root via window.__demoRoot
    // because document.currentScript is unreliable for dynamically
    // inserted scripts.
    for (const def of scripts) {
      const scriptEl = document.createElement('script');
      if (def.type) scriptEl.type = def.type;

      if (def.src) {
        scriptEl.src = def.src;
        const loaded = new Promise<void>((resolve, reject) => {
          scriptEl.addEventListener('load', () => resolve(), { once: true });
          scriptEl.addEventListener(
            'error',
            () => reject(new Error('failed to load ' + def.src)),
            { once: true },
          );
        });
        shadow.appendChild(scriptEl);
        try {
          await loaded;
        } catch (err) {
          console.error(err);
        }
      } else {
        scriptEl.textContent = `(function(){\n${def.body}\n})();`;
        (window as unknown as { __demoRoot?: ShadowRoot }).__demoRoot = shadow;
        try {
          shadow.appendChild(scriptEl);
        } finally {
          delete (window as unknown as { __demoRoot?: ShadowRoot }).__demoRoot;
        }
      }
    }
  }

  function initDemoFallback() {
    const fallback = document.getElementById('demo-fallback');
    if (!fallback) return;

    const isSupported =
      typeof CanvasRenderingContext2D !== 'undefined' &&
      ('drawElementImage' in CanvasRenderingContext2D.prototype ||
        'drawElement' in CanvasRenderingContext2D.prototype);

    fallback.hidden = isSupported;
  }

  function initFullscreenButton() {
    const stage = document.getElementById('demo-stage');
    const btn = document.getElementById('demo-fullscreen-btn');
    if (!stage || !btn) return;

    btn.addEventListener('click', () => {
      if (document.fullscreenElement) {
        document.exitFullscreen();
      } else {
        stage.requestFullscreen().catch(() => {
          /* user gesture required or unsupported — ignore */
        });
      }
    });
  }

  function init() {
    initDemoFallback();
    if (
      typeof CanvasRenderingContext2D !== 'undefined' &&
      ('drawElementImage' in CanvasRenderingContext2D.prototype ||
        'drawElement' in CanvasRenderingContext2D.prototype)
    ) {
      mountDemo();
    }
    initFullscreenButton();
  }

  init();
  document.addEventListener('astro:after-swap', init);
</script>

<style>
  /* ------- Page ------- */
  .demo-page {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* ------- Slim title bar ------- */
  .demo-bar {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-wrap: wrap;
    padding-bottom: 0.25rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-muted);
    transition: color 0.15s ease;
    text-decoration: none;
  }

  .back-link:hover {
    color: var(--text-primary);
    text-decoration: none;
  }

  .bar-divider {
    width: 1px;
    height: 1.25rem;
    background: var(--border-color);
  }

  .bar-title {
    font-size: 1.05rem;
    font-weight: 700;
    margin: 0;
    color: var(--text-primary);
    line-height: 1.2;
  }

  .bar-actions {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    margin-left: auto;
  }

  .bar-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 6px;
    border: 1px solid var(--border-color);
    background: var(--bg-surface);
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.15s ease, background-color 0.15s ease,
      border-color 0.15s ease;
  }

  .bar-action:hover {
    color: var(--text-primary);
    background: var(--bg-elevated);
    border-color: var(--accent);
  }

  .demo-description {
    margin: 0;
    color: var(--text-secondary);
    max-width: 52rem;
    font-size: 0.9rem;
  }

  /* ------- Badges (shared palette with DemoCard) ------- */
  .context-badge,
  .difficulty-badge {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.175rem 0.5rem;
    border-radius: 4px;
    line-height: 1.4;
  }

  .context-2d {
    background: rgba(0, 229, 185, 0.15);
    color: var(--color-teal);
  }

  .context-webgl {
    background: rgba(255, 89, 38, 0.15);
    color: var(--color-orange);
  }

  .context-webgpu {
    background: rgba(108, 65, 240, 0.15);
    color: var(--color-purple);
  }

  .difficulty-beginner {
    background: rgba(0, 189, 129, 0.12);
    color: var(--color-green);
  }

  .difficulty-intermediate {
    background: rgba(255, 89, 38, 0.12);
    color: var(--color-orange);
  }

  .difficulty-advanced {
    background: rgba(213, 46, 102, 0.12);
    color: var(--color-pink);
  }

  /* ------- Demo stage (full-bleed shadow mount) ------- */
  /*
   * The .demo-stage-wrapper breaks out of <main>'s max-width and
   * padding using the 100vw + negative margin trick, so the demo
   * stage stretches edge-to-edge across the viewport.
   */
  .demo-stage-wrapper {
    position: relative;
    width: 100vw;
    margin-left: calc(50% - 50vw);
  }

  .demo-stage {
    position: relative;
    display: block;
    width: 100%;
    height: min(78vh, 820px);
    min-height: 32rem;
    border-block: 1px solid var(--border-color);
    background: #0a0a0a;
    overflow: hidden;
  }

  .demo-stage:fullscreen {
    width: 100vw;
    height: 100vh;
    max-height: none;
    border: none;
  }

  /* ------- Fullscreen toggle ------- */
  .demo-fullscreen-btn {
    position: absolute;
    top: 0.625rem;
    right: 0.625rem;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 6px;
    border: 1px solid var(--border-color);
    background: rgba(10, 10, 15, 0.7);
    color: var(--text-secondary);
    cursor: pointer;
    backdrop-filter: blur(8px);
    transition: color 0.15s ease, background-color 0.15s ease,
      border-color 0.15s ease;
  }

  .demo-fullscreen-btn:hover {
    color: var(--text-primary);
    background: rgba(10, 10, 15, 0.9);
    border-color: var(--accent);
  }

  .demo-fullscreen-btn:focus-visible {
    outline: 2px solid var(--color-purple);
    outline-offset: var(--focus-offset);
  }

  /* ------- Fallback overlay (API unavailable) ------- */
  .demo-fallback:not([hidden]) {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-surface);
    border-radius: 8px;
  }

  .fallback-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
    padding: 2rem;
    color: var(--text-muted);
  }

  .fallback-content svg {
    color: var(--color-orange);
    margin-bottom: 0.25rem;
  }

  .fallback-title {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .fallback-text {
    margin: 0;
    font-size: 0.85rem;
    color: var(--text-secondary);
    max-width: 24rem;
  }

  .fallback-text code {
    font-size: 0.8rem;
    padding: 0.1em 0.3em;
    background: rgba(255, 89, 38, 0.1);
    border-radius: 3px;
    color: var(--color-orange);
  }

  .fallback-link {
    font-size: 0.85rem;
    font-weight: 600;
    margin-top: 0.25rem;
  }

  /* ------- Details strip ------- */
  .demo-details {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));
    gap: 1rem 1.5rem;
    padding: 1rem 1.25rem;
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: 8px;
  }

  .detail-field {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    min-width: 0;
  }

  .detail-field-wide {
    grid-column: span 2;
  }

  .field-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-muted);
  }

  .field-value {
    font-size: 0.85rem;
    color: var(--text-primary);
  }

  .feature-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .feature-tag {
    font-size: 0.75rem;
    padding: 0.125rem 0.4rem;
    background: var(--bg-elevated);
    border-radius: 3px;
    color: var(--accent);
  }

  .browser-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .browser-badge {
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.125rem 0.4rem;
    border-radius: 3px;
  }

  .browser-badge.supported {
    background: rgba(0, 189, 129, 0.12);
    color: var(--color-green);
  }

  .browser-badge.unsupported {
    background: var(--bg-elevated);
    color: var(--text-muted);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .demo-tag {
    font-size: 0.7rem;
    padding: 0.125rem 0.4rem;
    background: var(--bg-elevated);
    color: var(--text-muted);
    border-radius: 3px;
  }

  /* ------- Source section ------- */
  .demo-source h2 {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
  }

  /* ------- Responsive ------- */
  @media (max-width: 768px) {
    .demo-stage {
      height: 65vh;
      min-height: 24rem;
    }

    .demo-details {
      grid-template-columns: 1fr;
    }

    .detail-field-wide {
      grid-column: auto;
    }
  }
</style>
