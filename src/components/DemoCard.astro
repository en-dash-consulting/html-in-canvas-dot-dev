---
/**
 * Card component for the demo gallery.
 * Displays title, description, context badge, difficulty, and tags.
 */

interface Props {
  slug: string;
  title: string;
  description: string;
  context: '2d' | 'webgl' | 'webgpu';
  difficulty: 'beginner' | 'intermediate' | 'advanced';
  tags: string[];
  /** Heading level for the card title. Defaults to h3 (cards sit under
   *  an h2 section heading on the home page). On pages where the cards
   *  sit directly under the page h1 (e.g. /demos/), pass 2 to avoid a
   *  heading-level skip. */
  headingLevel?: 2 | 3;
}

const {
  slug,
  title,
  description,
  context,
  difficulty,
  tags,
  headingLevel = 3,
} = Astro.props;
const HeadingTag = `h${headingLevel}` as 'h2' | 'h3';

const contextLabels: Record<string, string> = {
  '2d': '2D',
  webgl: 'WebGL',
  webgpu: 'WebGPU',
};

const difficultyLabels: Record<string, string> = {
  beginner: 'Beginner',
  intermediate: 'Intermediate',
  advanced: 'Advanced',
};
---

<a href={`/demos/${slug}/`} class="demo-card" data-context={context} data-difficulty={difficulty} data-tags={tags.join(',')}>
  <div class="demo-card-header">
    <span class={`context-badge context-${context}`}>{contextLabels[context]}</span>
    <span class={`difficulty-badge difficulty-${difficulty}`}>{difficultyLabels[difficulty]}</span>
  </div>
  <HeadingTag class="demo-card-title">{title}</HeadingTag>
  <p class="demo-card-desc">{description}</p>
  {tags.length > 0 && (
    <div class="demo-card-tags">
      {tags.map((tag) => (
        <span class="demo-tag">{tag}</span>
      ))}
    </div>
  )}
</a>

<style>
  .demo-card {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    padding: 1.25rem;
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
  }

  .demo-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
    text-decoration: none;
  }

  .demo-card-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .context-badge,
  .difficulty-badge {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.2rem 0.55rem;
    border-radius: 4px;
    line-height: 1.4;
  }

  .context-2d {
    background: var(--badge-teal-bg);
    color: var(--accent-teal-text);
  }

  .context-webgl {
    background: var(--badge-orange-bg);
    color: var(--accent-orange-text);
  }

  .context-webgpu {
    background: var(--badge-purple-bg);
    color: var(--accent-purple-text);
  }

  .difficulty-beginner {
    background: var(--badge-green-bg);
    color: var(--accent-green-text);
  }

  .difficulty-intermediate {
    background: var(--badge-orange-bg);
    color: var(--accent-orange-text);
  }

  .difficulty-advanced {
    background: var(--badge-pink-bg);
    color: var(--accent-pink-text);
  }

  .demo-card-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0;
  }

  .demo-card-desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.5;
  }

  .demo-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: auto;
  }

  .demo-tag {
    font-size: 0.7rem;
    font-weight: 500;
    padding: 0.15rem 0.45rem;
    background: var(--bg-elevated);
    color: var(--text-secondary);
    border-radius: 3px;
  }
</style>
