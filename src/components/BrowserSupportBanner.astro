---
/**
 * Browser support banner — warns visitors when the HTML-in-Canvas API
 * (`CanvasRenderingContext2D.prototype.drawElementImage`) is unavailable.
 *
 * Behaviour:
 *  - Hidden when the API is detected (feature detection).
 *  - On demo pages (`/demos/{slug}/`): always visible, dismiss button hidden.
 *  - On other pages: dismissible — state persisted to localStorage.
 *  - Links to /docs/browser-support/ for setup instructions.
 */
---

<div
  class="browser-banner"
  id="browser-banner"
  role="alert"
  hidden
>
  <div class="banner-inner">
    {/* Warning icon */}
    <svg
      class="banner-icon"
      xmlns="http://www.w3.org/2000/svg"
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z" />
      <line x1="12" y1="9" x2="12" y2="13" />
      <line x1="12" y1="17" x2="12.01" y2="17" />
    </svg>

    <p class="banner-message">
      This site needs the
      <code>canvas-draw-element</code>
      flag — enabled in
      <strong>Chrome Canary</strong>
      or
      <strong>Brave Stable</strong>
      (Chromium 147+).
      <a href="/docs/browser-support/">Setup instructions&nbsp;&rarr;</a>
    </p>

    <button
      class="banner-dismiss"
      id="banner-dismiss"
      type="button"
      aria-label="Dismiss browser support banner"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
  </div>
</div>

<script>
  function initBrowserBanner() {
    const banner = document.getElementById('browser-banner');
    const dismissBtn = document.getElementById('banner-dismiss');
    if (!banner || !dismissBtn) return;

    const STORAGE_KEY = 'hic-banner-dismissed';

    const isSupported =
      typeof CanvasRenderingContext2D !== 'undefined' &&
      'drawElementImage' in CanvasRenderingContext2D.prototype;

    // API available — no banner needed
    if (isSupported) return;

    const pathname = window.location.pathname;
    const isDemoPage =
      pathname.startsWith('/demos/') &&
      pathname !== '/demos/' &&
      pathname !== '/demos';

    if (isDemoPage) {
      // Always visible on demo pages — hide the dismiss button
      banner.hidden = false;
      dismissBtn.hidden = true;
      return;
    }

    // Non-demo page: respect localStorage dismissal
    if (localStorage.getItem(STORAGE_KEY) === 'true') return;

    banner.hidden = false;

    dismissBtn.addEventListener('click', () => {
      banner.hidden = true;
      localStorage.setItem(STORAGE_KEY, 'true');
    });
  }

  initBrowserBanner();
  document.addEventListener('astro:after-swap', initBrowserBanner);
</script>

<style>
  .browser-banner {
    background: rgba(255, 89, 38, 0.08);
    border-bottom: 1px solid rgba(255, 89, 38, 0.2);
  }

  .banner-inner {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0.5rem 1.5rem;
  }

  .banner-icon {
    flex-shrink: 0;
    color: var(--color-orange);
  }

  .banner-message {
    flex: 1;
    margin: 0;
    font-size: 0.85rem;
    line-height: 1.4;
    color: var(--text-primary);
  }

  .banner-message code {
    font-size: 0.8rem;
    padding: 0.1em 0.3em;
    background: rgba(255, 89, 38, 0.1);
    border-radius: 3px;
    color: var(--color-orange);
  }

  .banner-message a {
    font-weight: 600;
    white-space: nowrap;
  }

  .banner-dismiss {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border: none;
    border-radius: 4px;
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    transition: color 0.15s ease, background-color 0.15s ease;
  }

  .banner-dismiss:hover {
    color: var(--text-primary);
    background: rgba(255, 89, 38, 0.12);
  }

  .banner-dismiss:focus-visible {
    outline: 2px solid var(--color-purple);
    outline-offset: var(--focus-offset);
  }
</style>
