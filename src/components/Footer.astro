---
/**
 * Site footer — matches the learn-pretext.com layout: a slim gradient
 * accent, a small uppercase eyebrow, a big "built by" headline, a
 * contribution call-to-action linking to the GitHub repo, a tagline,
 * and a CTA button to the En Dash Consulting site.
 */
const GITHUB_REPO =
  'https://github.com/en-dash-consulting/html-in-canvas-dot-dev';
---

<footer class="site-footer">
  <div class="footer-container">
    <div class="footer-accent" aria-hidden="true"></div>
    <p class="footer-eyebrow">This HTML-in-Canvas demo showcase was</p>
    <h2 class="footer-headline">
      Built for people everywhere, by people at
      <span class="endash-mark">En Dash</span>
    </h2>
    <p class="footer-contribute">
      And&hellip; Your Name Here!
      <a href={GITHUB_REPO} target="_blank" rel="noopener noreferrer">
        Contribute on GitHub :D
      </a>
    </p>
    <p class="footer-tagline">
      We build tools that make work better and feel better.
    </p>
    <a
      class="footer-cta"
      href="https://endash.us"
      target="_blank"
      rel="noopener noreferrer"
    >
      Learn more about En Dash <span aria-hidden="true">→</span>
    </a>
    <p class="footer-colophon">
      Built with <a href="https://n-dx.dev" target="_blank" rel="noopener noreferrer">n-dx</a> and <a href="https://claude.com" target="_blank" rel="noopener noreferrer">Claude</a>.
    </p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border-color);
    background-color: var(--bg-secondary);
    padding: 3.5rem 1.5rem 4rem;
    margin-top: auto;
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }

  .footer-container {
    max-width: 48rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
    text-align: center;
  }

  /* Slim gradient accent line at the top of the footer block */
  .footer-accent {
    width: 3.5rem;
    height: 3px;
    border-radius: 2px;
    background: linear-gradient(
      90deg,
      var(--color-teal),
      var(--color-purple)
    );
    margin-bottom: 0.75rem;
  }

  .footer-eyebrow {
    margin: 0;
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--text-muted);
  }

  .footer-headline {
    margin: 0;
    font-size: clamp(1.4rem, 3.5vw, 2rem);
    font-weight: 800;
    line-height: 1.25;
    color: var(--text-primary);
    max-width: 30ch;
    letter-spacing: -0.01em;
  }

  .endash-mark {
    background: linear-gradient(
      90deg,
      var(--color-teal),
      var(--color-purple)
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    white-space: nowrap;
  }

  .footer-contribute {
    margin: 0.25rem 0 0;
    font-size: 1rem;
    color: var(--text-secondary);
  }

  .footer-contribute a {
    color: var(--color-purple);
    font-weight: 600;
    text-decoration: none;
  }

  .footer-contribute a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .footer-tagline {
    margin: 0.25rem 0 0;
    font-size: 1rem;
    color: var(--text-secondary);
    max-width: 36ch;
  }

  .footer-cta {
    margin-top: 1.25rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.4rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-primary);
    background: transparent;
    border: 1px solid var(--border-color);
    border-radius: 999px;
    text-decoration: none;
    transition: border-color 0.15s ease, color 0.15s ease,
      background-color 0.15s ease, transform 0.15s ease;
  }

  .footer-cta:hover {
    border-color: var(--color-teal);
    color: var(--color-teal);
    transform: translateY(-1px);
    text-decoration: none;
  }

  .footer-cta:focus-visible {
    outline: 2px solid var(--color-purple);
    outline-offset: var(--focus-offset);
  }

  .footer-colophon {
    margin: 1.75rem 0 0;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .footer-colophon a {
    color: var(--text-secondary);
    font-weight: 500;
    text-decoration: none;
    border-bottom: 1px solid var(--border-color);
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .footer-colophon a:hover {
    color: var(--color-teal);
    border-bottom-color: var(--color-teal);
    text-decoration: none;
  }
</style>
