---
/**
 * Layout for documentation pages.
 * Renders a sidebar with ordered navigation links alongside the doc content.
 */
import { getCollection } from 'astro:content';
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  /** Current page slug, used to highlight the active nav item */
  currentSlug: string;
}

const { title, currentSlug } = Astro.props;

const allDocs = await getCollection('docs');
const sortedDocs = allDocs.sort((a, b) => a.data.order - b.data.order);

// Breadcrumb JSON-LD for every docs page — Home › Docs › {Doc Title}.
const SITE_URL = 'https://html-in-canvas.dev';
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE_URL}/` },
    { '@type': 'ListItem', position: 2, name: 'Documentation', item: `${SITE_URL}/docs/` },
    {
      '@type': 'ListItem',
      position: 3,
      name: title,
      item: `${SITE_URL}/docs/${currentSlug}/`,
    },
  ],
};
---

<BaseLayout
  title={title}
  description={`${title} — HTML-in-Canvas specification documentation.`}
  ogImage="/og-docs.png"
>
  <Fragment slot="head">
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(breadcrumbJsonLd)}
    />
    {/* Forwarded from individual doc pages (e.g. HowTo JSON-LD for
        browser-support). */}
    <slot name="head" />
  </Fragment>
  <div class="docs-layout">
    <aside class="docs-sidebar" aria-label="Documentation navigation">
      <nav>
        <h2 class="sidebar-title">Documentation</h2>
        <ul class="sidebar-nav">
          {sortedDocs.map((doc) => (
            <li>
              <a
                href={`/docs/${doc.id}/`}
                class:list={['sidebar-link', { active: doc.id === currentSlug }]}
                aria-current={doc.id === currentSlug ? 'page' : undefined}
              >
                {doc.data.title}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>

    <article class="docs-content">
      <slot />
    </article>
  </div>
</BaseLayout>

<style>
  .docs-layout {
    display: grid;
    grid-template-columns: 14rem 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  /* ------- Sidebar ------- */
  .docs-sidebar {
    position: sticky;
    top: calc(var(--nav-height) + 2rem);
    max-height: calc(100dvh - var(--nav-height) - 4rem);
    overflow-y: auto;
  }

  .sidebar-title {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  .sidebar-nav {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .sidebar-link {
    display: block;
    padding: 0.375rem 0.75rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    border-radius: 6px;
    transition: color 0.15s ease, background-color 0.15s ease;
  }

  .sidebar-link:hover {
    color: var(--text-primary);
    background: var(--bg-surface);
    text-decoration: none;
  }

  .sidebar-link.active {
    color: var(--text-primary);
    background: var(--bg-surface);
    font-weight: 600;
  }

  /* ------- Content ------- */
  .docs-content {
    min-width: 0;
    max-width: 52rem;
  }

  /* Prose styles for rendered markdown */
  .docs-content :global(h1) {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .docs-content :global(h2) {
    font-size: 1.5rem;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.375rem;
    border-bottom: 1px solid var(--border-subtle);
  }

  .docs-content :global(h3) {
    font-size: 1.15rem;
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
  }

  .docs-content :global(h4) {
    font-size: 1rem;
    margin-top: 1.25rem;
    margin-bottom: 0.375rem;
  }

  .docs-content :global(p) {
    margin-block: 0.75em;
    line-height: 1.7;
  }

  .docs-content :global(ul),
  .docs-content :global(ol) {
    margin-block: 0.75em;
    padding-left: 1.5rem;
  }

  .docs-content :global(li) {
    margin-block: 0.25em;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  .docs-content :global(strong) {
    color: var(--text-primary);
    font-weight: 600;
  }

  .docs-content :global(a) {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .docs-content :global(pre) {
    margin-block: 1rem;
    font-size: 0.85rem;
    line-height: 1.55;
  }

  .docs-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-block: 1rem;
    font-size: 0.85rem;
  }

  .docs-content :global(th),
  .docs-content :global(td) {
    text-align: left;
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--border-color);
  }

  .docs-content :global(th) {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-muted);
    background: var(--bg-surface);
  }

  .docs-content :global(td) {
    color: var(--text-secondary);
  }

  .docs-content :global(hr) {
    border: none;
    border-top: 1px solid var(--border-color);
    margin-block: 2rem;
  }

  .docs-content :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding: 0.5rem 1rem;
    margin-block: 1rem;
    background: var(--bg-surface);
    border-radius: 0 6px 6px 0;
  }

  .docs-content :global(blockquote p) {
    margin: 0;
  }

  /* ------- Responsive ------- */
  @media (max-width: 768px) {
    .docs-layout {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .docs-sidebar {
      position: static;
      max-height: none;
      padding: 1rem;
      background: var(--bg-surface);
      border: 1px solid var(--border-color);
      border-radius: 8px;
    }
  }
</style>
