---
/**
 * Base layout for all pages.
 * Renders nav, footer, and global styles.
 */
import Nav from '../components/Nav.astro';
import BrowserSupportBanner from '../components/BrowserSupportBanner.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'HTML-in-Canvas',
  description = 'Interactive demos and documentation for the WICG HTML-in-Canvas specification.',
} = Astro.props;

const pageTitle = title === 'HTML-in-Canvas' ? title : `${title} | HTML-in-Canvas`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" href="/favicon.ico" />
    <title>{pageTitle}</title>
    {/* Prevent FOUC: apply saved theme before first paint */}
    <script is:inline>
      (function() {
        const theme = localStorage.getItem('theme');
        document.documentElement.setAttribute(
          'data-theme',
          theme === 'light' ? 'light' : 'dark'
        );
      })();
    </script>
  </head>
  <body>
    <Nav />
    <BrowserSupportBanner />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
