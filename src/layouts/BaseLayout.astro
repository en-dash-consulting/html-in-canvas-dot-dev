---
/**
 * Base layout for all pages.
 * Renders nav, footer, global styles, and the full SEO/social meta
 * stack: title, description, canonical URL, Open Graph, Twitter Card,
 * theme color, author, and a JSON-LD WebSite/Organization graph.
 */
import Nav from '../components/Nav.astro';
import BrowserSupportBanner from '../components/BrowserSupportBanner.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  /** Path to a per-page social card image (relative to /). */
  ogImage?: string;
  /** Alt text for the social card image. Defaults to the social title
   *  (which mirrors what the card itself displays). */
  ogImageAlt?: string;
  /** Override the default page type for Open Graph. */
  ogType?: 'website' | 'article';
}

const SITE_NAME = 'HTML-in-Canvas';
const SITE_URL = 'https://html-in-canvas.dev';
const DEFAULT_DESCRIPTION =
  'Interactive demos and documentation for the WICG HTML-in-Canvas specification — render real DOM elements directly into a <canvas> via drawElementImage().';
const DEFAULT_OG_IMAGE = '/og-image.png';
// Short site tagline appended to the social title when the page-level
// title alone would fall under social platforms' ~30-char minimum.
// Keeps og:title / twitter:title descriptive even on short-named pages
// like "Demos" or the home page.
const SOCIAL_TAGLINE = 'Render HTML into <canvas> — natively';

// Twitter handles. The site doesn't have its own dedicated handle, so
// twitter:site reuses the maintainer's handle — the standard fallback
// when an organization brand handle doesn't exist.
const TWITTER_HANDLE = '@the_duke_nd';

// Google Analytics 4 measurement ID. Read from an env var if set so
// forks can point the site at their own property without touching
// source; falls back to the canonical html-in-canvas.dev ID. Set to an
// empty string (`PUBLIC_GA_MEASUREMENT_ID=`) to disable.
const GA_MEASUREMENT_ID =
  (import.meta.env.PUBLIC_GA_MEASUREMENT_ID ?? 'G-GZ5SK3LLBF') as string;

// Only inject GA in production builds so `npm run dev` doesn't pollute
// analytics and so local work never shows up in the dashboard.
const enableGa = import.meta.env.PROD && GA_MEASUREMENT_ID.length > 0;

const {
  title = SITE_NAME,
  description = DEFAULT_DESCRIPTION,
  ogImage = DEFAULT_OG_IMAGE,
  ogImageAlt,
  ogType = 'website',
} = Astro.props;

const pageTitle =
  title === SITE_NAME ? SITE_NAME : `${title} | ${SITE_NAME}`;

// Social title is decoupled from the browser-tab <title> so it can be
// padded to clear social platforms' ~30-char minimum without bloating
// the tab label. Pad with the site tagline whenever pageTitle is
// short; otherwise reuse pageTitle as-is.
const SOCIAL_TITLE_MIN = 30;
const socialTitle =
  pageTitle === SITE_NAME
    ? `${SITE_NAME} — ${SOCIAL_TAGLINE}`
    : pageTitle.length >= SOCIAL_TITLE_MIN
      ? pageTitle
      : `${title} — ${SOCIAL_TAGLINE} | ${SITE_NAME}`;

// Default the image alt text to the social title so the alt always
// matches what the card visually displays. Per-page overrides via prop.
const socialImageAlt = ogImageAlt ?? socialTitle;

// In dev, resolve URLs against the actual request origin (e.g.
// http://localhost:4321) so social-preview tooling pointed at the
// local server can fetch the image. In prod, use the configured
// `Astro.site` so canonical/OG URLs match the published domain.
const baseURL = import.meta.env.DEV ? Astro.url.origin : (Astro.site ?? SITE_URL);
const canonicalURL = new URL(Astro.url.pathname, baseURL).href;
const ogImageURL = new URL(ogImage, baseURL).href;

// JSON-LD only included on the home page; demo pages emit their own
// CreativeWork JSON-LD via a slot.
const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '';
const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE_NAME,
  url: SITE_URL,
  description: DEFAULT_DESCRIPTION,
  inLanguage: 'en',
  publisher: {
    '@type': 'Organization',
    name: 'En Dash Consulting',
    url: 'https://endash.us',
  },
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    {/* Core SEO */}
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content="En Dash Consulting" />
    {/* Allow indexing + crawling, and let Google show large image
        previews in search results (powers the OG image in SERPs). */}
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="theme-color" content="#0a0a0f" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#fafafa" media="(prefers-color-scheme: light)" />

    {/* Favicon — En Dash brand mark, copied from endash.us. */}
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />

    {/* Open Graph */}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={socialTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={socialImageAlt} />
    <meta property="og:locale" content="en_US" />

    {/* Twitter Card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={TWITTER_HANDLE} />
    <meta name="twitter:creator" content={TWITTER_HANDLE} />
    <meta name="twitter:title" content={socialTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content={socialImageAlt} />

    {/* JSON-LD on the home page */}
    {isHome && (
      <script
        is:inline
        type="application/ld+json"
        set:html={JSON.stringify(websiteJsonLd)}
      />
    )}

    {/* Per-page slot for additional <link>, <meta>, or JSON-LD */}
    <slot name="head" />

    {/* Google Analytics 4 — production only, gated on env var */}
    {enableGa && (
      <>
        <script
          is:inline
          async
          src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`}
        />
        <script is:inline define:vars={{ GA_MEASUREMENT_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', GA_MEASUREMENT_ID);
        </script>
      </>
    )}

    {/* Prevent FOUC: apply saved theme before first paint */}
    <script is:inline>
      (function() {
        const theme = localStorage.getItem('theme');
        document.documentElement.setAttribute(
          'data-theme',
          theme === 'light' ? 'light' : 'dark'
        );
      })();
    </script>

    {/* Flag detection before first paint so CSS can pick the right
        hero variant without a flash. Runs synchronously in <head>,
        before body parsing, so the attribute is set when the browser
        first evaluates CSS selectors for the page. Failure modes
        (non-Chromium, flag off, older builds) all resolve to "false". */}
    <script is:inline>
      (function() {
        try {
          var proto = window.CanvasRenderingContext2D &&
            window.CanvasRenderingContext2D.prototype;
          var supported = !!proto && (
            'drawElementImage' in proto ||
            'drawElement' in proto
          );
          document.documentElement.setAttribute(
            'data-flag-supported',
            supported ? 'true' : 'false'
          );
        } catch (e) {
          document.documentElement.setAttribute(
            'data-flag-supported',
            'false'
          );
        }
      })();
    </script>
  </head>
  <body>
    <Nav />
    <BrowserSupportBanner />
    <main>
      <slot />
    </main>
    <Footer />
    {/* Scrollable <pre> blocks must be keyboard-reachable (WCAG 2.1.1).
        `pre` has `overflow-x: auto` in the global styles, so any content
        that exceeds the viewport width becomes a horizontal scroll
        region with no keyboard access. Adding tabindex=0 makes the
        block focusable so keyboard users can scroll it with arrow keys. */}
    <script is:inline>
      function markScrollablePreFocusable() {
        document.querySelectorAll('pre:not([tabindex])').forEach((pre) => {
          pre.tabIndex = 0;
        });
      }
      markScrollablePreFocusable();
      document.addEventListener('astro:after-swap', markScrollablePreFocusable);
    </script>
  </body>
</html>
